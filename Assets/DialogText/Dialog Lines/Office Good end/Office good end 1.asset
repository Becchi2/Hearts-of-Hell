  m_Script: {fileID: 11500000, guid: 1916a287e7d4abf448f52361f3e8cb1c, type: 3}
  m_Name: Office good end 1
  m_EditorClassIdentifier: Assembly-CSharp::Dialog
  lines:
  - speaker: Supervisor
    line: Yo yo yo. How are we doing this fine evening newbie?
    SpriteRange: 0
  - speaker: You
    line: "I\u2019m feeling pretty good honestly"
    SpriteRange: 0
  - speaker: Supervisor
    line: Yeah you should be. You managed to take down slitmouth all by yourself
      without having to fight her.
    SpriteRange: 0
  - speaker: Supervisor
    line: "That\u2019s unheard of from a new up and coming exorcist. "
    SpriteRange: 0
  - speaker: Supervisor
    line: You should be proud.
    SpriteRange: 0
  - speaker: You
    line: "Yeah thanks\u2026Is it weird that I kind of feel sad that she\u2019s gone."
    SpriteRange: 0
  - speaker: Supervisor
    line: "Man don\u2019t beat yourself up about it. Our job as exorcists is to help
      these spirits move on, one way or another. "
    SpriteRange: 0
  - speaker: Supervisor
    line: 'Whether that''s through killing them in battle, or speaking to them. '
    SpriteRange: 0
  - speaker: Supervisor
    line: "We just gotta make sure they leave the earth. And with the way you handled
      it, I can assure you that she\u2019s in a better place. "
    SpriteRange: 0
  - speaker: Supervisor
    line: "You gave her what she needed, closure and security. That\u2019s all that
      matters in the end."
    SpriteRange: 0
  - speaker: You
    line: ...yeah yeah I see what you mean. Thanks
    SpriteRange: 0
  - speaker: Supervisor
    line: "Don\u2019t sweat it newbie. I\u2019ll check in tomorrow. Goodnight."
    SpriteRange: 0
  buttons: []
