  m_Script: {fileID: 11500000, guid: 1916a287e7d4abf448f52361f3e8cb1c, type: 3}
  m_Name: SM night 1
  m_EditorClassIdentifier: Assembly-CSharp::Dialog
  lines:
  - speaker: Kuchisake-Onna
    line: Well well. It seems as though you did know where you needed to go after
      all.
    SpriteRange: 5
  - speaker: Kuchisake-Onna
    line: So how were you able to find me?
    SpriteRange: 5
  - speaker: You
    line: Call it a hunch.
    SpriteRange: 5
  - speaker: Kuchisake-Onna
    line: A hunch?
    SpriteRange: 5
  - speaker: Kuchisake-Onna
    line: Let's hope your "hunch"can help me.
    SpriteRange: 5
  - speaker: You
    line: I wanted to ask you...
    SpriteRange: 5
  - speaker: You
    line: how much do you remember from the time you were alive?
    SpriteRange: 5
  buttons: []
