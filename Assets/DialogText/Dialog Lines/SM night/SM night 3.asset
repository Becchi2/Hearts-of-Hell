  m_Name: SM night 3
  m_EditorClassIdentifier: Assembly-CSharp::Dialog
  lines:
  - speaker: Kuchisake-Onna
    line: 'Everytime I think back. '
    SpriteRange: 4
  - speaker: Kuchisake-Onna
    line: 'Back to that time. '
    SpriteRange: 4
  - speaker: Kuchisake-Onna
    line: "I\u2019m filled with so much rage, anger and jealousy. "
    SpriteRange: 2
  - speaker: Kuchisake-Onna
    line: 'But at what? '
    SpriteRange: 4
  - speaker: Kuchisake-Onna
    line: I cannot remember for the life of me.
    SpriteRange: 5
  - speaker: You
    line: 'Was it not someone? '
    SpriteRange: 5
  - speaker: You
    line: I don't know... a lover?
    SpriteRange: 5
  buttons: []
