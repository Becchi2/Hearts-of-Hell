  m_Script: {fileID: 11500000, guid: 1916a287e7d4abf448f52361f3e8cb1c, type: 3}
  m_Name: SM Afternoon talk to you
  m_EditorClassIdentifier: Assembly-CSharp::Dialog
  lines:
  - speaker: You
    line: "I don\u2019t know about you but I\u2019m just here to talk."
    SpriteRange: 5
  - speaker: Kuchisake-Onna
    line: 'Oh is that why you were so adamant on meeting me? '
    SpriteRange: 5
  - speaker: Kuchisake-Onna
    line: 'Did I leave that much of an impression? '
    SpriteRange: 8
  - speaker: Kuchisake-Onna
    line: I will say though, I am rather flattered that I have a spot in your mind.
    SpriteRange: 6
  - speaker: You
    line: 'What could you possibly gain from all this killing? '
    SpriteRange: 5
  - speaker: You
    line: You seem pretty different from the other spirits i've encountered.
    SpriteRange: 5
  buttons: []
