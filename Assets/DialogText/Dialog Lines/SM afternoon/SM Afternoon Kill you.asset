  m_Script: {fileID: 11500000, guid: 1916a287e7d4abf448f52361f3e8cb1c, type: 3}
  m_Name: SM Afternoon Kill you
  m_EditorClassIdentifier: Assembly-CSharp::Dialog
  lines:
  - speaker: You
    line: My job is to exorcize spirits by any means necessary.
    SpriteRange: 3
  - speaker: You
    line: If that means killing you then so be it.
    SpriteRange: 2
  - speaker: Kuchisake-Onna
    line: Oh. And here I thought you were going to be different. All you people are
      all the same.
    SpriteRange: 2
  - speaker: Kuchisake-Onna
    line: "I\u2019ll take great pleasure in ripping you to shreds!"
    SpriteRange: 2
