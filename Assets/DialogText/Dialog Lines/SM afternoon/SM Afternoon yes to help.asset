  m_Script: {fileID: 11500000, guid: 1916a287e7d4abf448f52361f3e8cb1c, type: 3}
  m_Name: SM Afternoon yes to help
  m_EditorClassIdentifier: Assembly-CSharp::Dialog
  lines:
  - speaker: You
    line: "Yeah. My job is to ensure that you can\u2019t harm anybody else."
    SpriteRange: 10
  - speaker: You
    line: "If I can do that without having to fight you, then I\u2019ll do it."
    SpriteRange: 8
  - speaker: Kuchisake-Onna
    line: "Why\u2026thank you! I truly am at a loss for words."
    SpriteRange: 10
  - speaker: You
    line: "Don\u2019t worry about it."
    SpriteRange: 10
  - speaker: Kuchisake-onna
    line: Then until we meet again. You know where to find me.
    SpriteRange: 10
